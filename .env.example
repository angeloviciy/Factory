# DigitalOcean API token (full access — read + write)
# Get one at: https://cloud.digitalocean.com/account/api/tokens
DO_API_TOKEN=dop_v1_xxxx

# Your SSH key fingerprint registered with DigitalOcean
# Find it: doctl compute ssh-key list
DO_SSH_KEY_FINGERPRINT=ab:cd:ef:00:11:22:33:44:55:66:77:88:99:aa:bb:cc

# GitHub personal access token (fine-grained, repo scope)
# Create at: https://github.com/settings/personal-access-tokens/new
GH_TOKEN=github_pat_xxxx

# Default repo to clone (owner/name)
DEFAULT_REPO=angel/BrainPal

# Default DigitalOcean region
DO_REGION=nyc1

# Default droplet size (s-2vcpu-4gb = $0.036/hr)
DO_SIZE=s-2vcpu-4gb

# Webhook URL for agent completion notifications (optional)
# Run `factory notify-setup` to auto-configure with ntfy.sh
FACTORY_WEBHOOK_URL=
